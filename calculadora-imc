package com.example.calculadoraimc

import android.os.Bundle
import android.view.View
import android.widget.Button
import android.widget.EditText
import android.widget.SeekBar
import android.widget.SeekBar.OnSeekBarChangeListener
import android.widget.TextView
import android.widget.Toast
import androidx.activity.enableEdgeToEdge
import androidx.appcompat.app.AppCompatActivity
import androidx.core.view.ViewCompat
import androidx.core.view.WindowInsetsCompat
import java.util.Locale

class MainActivity : AppCompatActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        setContentView(R.layout.activity_main)

        // CORREÇÃO: O código abaixo ajusta o layout para não ficar sob a barra de status
        val mainView = findViewById<View>(R.id.main)
        ViewCompat.setOnApplyWindowInsetsListener(mainView) { v, insets ->
            val systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars())
            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom)
            insets
        }

        // Referenciando os componentes do XML
        val editTextPeso = findViewById<EditText>(R.id.edit_text_peso)
        val seekBarAltura = findViewById<SeekBar>(R.id.seekbar_altura)
        val buttonLimpar = findViewById<Button>(R.id.button_limpar)
        val buttonCalcular = findViewById<Button>(R.id.button_calcular)
        val textViewHeightValor = findViewById<TextView>(R.id.textview_Altura)
        val textViewResult = findViewById<TextView>(R.id.textview_resultado)

        // Atualiza o texto da altura enquanto o usuário move a barra
        seekBarAltura.setOnSeekBarChangeListener(object : OnSeekBarChangeListener {
            override fun onProgressChanged(seekBar: SeekBar?, progress: Int, fromUser: Boolean) {
                textViewHeightValor.text = "$progress cm"
            }
            override fun onStartTrackingTouch(seekBar: SeekBar?) {}
            override fun onStopTrackingTouch(seekBar: SeekBar?) {}
        })

        // Ação do botão Calcular
        buttonCalcular.setOnClickListener {
            val pesoTexto = editTextPeso.text.toString()

            if (pesoTexto.isEmpty()) {
                Toast.makeText(this, "Digite o peso primeiro!", Toast.LENGTH_SHORT).show()
                return@setOnClickListener
            }

            val alturaEmMetros = seekBarAltura.progress.toDouble() / 100

            if (alturaEmMetros <= 0) {
                Toast.makeText(this, "Ajuste a altura na barra!", Toast.LENGTH_SHORT).show()
                return@setOnClickListener
            }

            try {
                val peso = pesoTexto.toDouble()
                val imc = peso / (alturaEmMetros * alturaEmMetros)

                textViewResult.text = String.format(Locale.getDefault(), "IMC: %.2f", imc)
                textViewResult.visibility = View.VISIBLE
            } catch (e: Exception) {
                Toast.makeText(this, "Erro no valor do peso", Toast.LENGTH_SHORT).show()
            }
        }

        // Ação do botão Limpar
        buttonLimpar.setOnClickListener {
            editTextPeso.setText("")
            seekBarAltura.progress = 0
            textViewHeightValor.text = "0 cm"
            textViewResult.visibility = View.GONE
        }
    }
}
  
